<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="copyd.exe"
        Arguments=""
        InstallLocation="C:\Program Files\André Lopes\copyd">
    </Installer>
    <PackageInformation
        PackageName="copyd"
        PackageDisplayName="copyd"
        PublisherName="CN=André Lopes"
        PublisherDisplayName="André Lopes"
        Version="0.1.0.0"
        PackageDescription="copyd — Wayland clipboard manager">
        <Capabilities>
            <Capability Name="runFullTrust" />

        </Capabilities>
        <Applications>
            <Application
                Id="com.andrelopes.copyd"
                Description="copyd — Wayland clipboard manager"
                DisplayName="copyd"
                ExecutableName="copyd.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>copyd</DisplayName>
            <PublisherDisplayName>André Lopes</PublisherDisplayName>
            <Description>copyd — Wayland clipboard manager</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="copyd.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
